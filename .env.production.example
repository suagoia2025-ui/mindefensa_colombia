# Copiar a .env.production en el servidor (no versionar).
ENVIRONMENT=production

# Origen del dataset: por defecto data/processed/eventos_seguridad_maestro en el volumen ./data
# Ejemplo alternativo en EC2:
# EVENTOS_MAESTRO_PATH=/app/data/parquet/eventos_seguridad_maestro

PYTHONPATH=/app
LOG_LEVEL=info

# CORS: lista separada por comas, o * para cualquier origen
ALLOWED_ORIGINS=http://127.0.0.1,http://localhost,http://TU_IP_PUBLICA
